{
  "name": "virtmcu",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "initializeCommand": "bash .devcontainer/initialize.sh",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "enableNonRootDocker": "true",
      "moby": "false"
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind",
    "source=${localEnv:HOME}/.claude.json,target=/home/vscode/.claude.json,type=bind",
    "source=${localEnv:HOME}/.config/gh,target=/home/vscode/.config/gh,type=bind"
  ],
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "rust-analyzer.check.command": "clippy"
      },
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "robocorp.robotframework-lsp",
        "ms-vscode.cpptools-extension-pack",
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "github.vscode-github-actions",
        "timonwong.shellcheck"
      ]
    }
  },
  "image": "ghcr.io/refractsystems/virtmcu/devenv:latest"
}