# ==============================================================================
# Makefile (Lesson 2: Dynamic Plugins)
#
# This Makefile triggers the build of the QEMU emulator, which in turn
# discovers and builds the dummy-device as a module.
# ==============================================================================

# Rely on the root Makefile to handle the QEMU module build process
build:
	$(MAKE) -C ../../ build

clean:
	@echo "Nothing to clean here. (Run 'make clean' in the root directory if needed)"
