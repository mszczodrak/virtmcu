from __future__ import annotations

import flatbuffers

type uoffset = flatbuffers.number_types.UOffsetTFlags.py_type

class RfHeader:
  @classmethod
  def GetRootAs(cls, buf: bytes, offset: int) -> RfHeader: ...
  @classmethod
  def GetRootAsRfHeader(cls, buf: bytes, offset: int) -> RfHeader: ...
  def Init(self, buf: bytes, pos: int) -> None: ...
  def DeliveryVtimeNs(self) -> int: ...
  def SequenceNumber(self) -> int: ...
  def Size(self) -> int: ...
  def Rssi(self) -> int: ...
  def Lqi(self) -> int: ...
def RfHeaderStart(builder: flatbuffers.Builder) -> None: ...
def Start(builder: flatbuffers.Builder) -> None: ...
def RfHeaderAddDeliveryVtimeNs(builder: flatbuffers.Builder, deliveryVtimeNs: int) -> None: ...
def RfHeaderAddSequenceNumber(builder: flatbuffers.Builder, sequenceNumber: int) -> None: ...
def RfHeaderAddSize(builder: flatbuffers.Builder, size: int) -> None: ...
def RfHeaderAddRssi(builder: flatbuffers.Builder, rssi: int) -> None: ...
def RfHeaderAddLqi(builder: flatbuffers.Builder, lqi: int) -> None: ...
def RfHeaderEnd(builder: flatbuffers.Builder) -> uoffset: ...
def End(builder: flatbuffers.Builder) -> uoffset: ...

